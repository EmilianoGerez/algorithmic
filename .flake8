[flake8]
# Maximum line length
max-line-length = 88

# Exclude directories
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    .env,
    dist,
    build,
    .tox,
    alembic/versions

# Ignore specific error codes - using command line format for compatibility with plugins
ignore = D,E402,E501,I100,I101,I201,I202

# Maximum cyclomatic complexity
max-complexity = 10

# Show source code for each error
show-source = True

# Count the number of occurrences of each error/warning code
count = True
